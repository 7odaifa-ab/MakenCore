{
  "name": "@zakhm_sa/makeen-core",
  "version": "1.0.2",
  "description": "Quran memorization planning engine — line-precise scheduling with mushaf spatial coordinates.",
  "author": "7odaifa-ab <hudaifa@zakhm.sa>",
  "contributors": [
    "Mohammed AlFreidi (original author)"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/7odaifa-ab/MakeenCore.git"
  },
  "homepage": "https://github.com/7odaifa-ab/MakeenCore#readme",
  "license": "ISC",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "README.ar.md",
    "USER_GUIDE.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=16"
  },
  "scripts": {
    "build": "tsc",
    "build:clean": "rmdir /s /q dist 2>nul & tsc",
    "start": "ts-node src/main.ts",
    "start:json": "ts-node src/main.ts --json",
    "start:excel": "ts-node src/main.ts --excel",
    "start:beginner": "ts-node src/main.ts --scenario=beginner",
    "start:beginner:excel": "ts-node src/main.ts --scenario=beginner --excel",
    "start:intermediate": "ts-node src/main.ts --scenario=intermediate",
    "start:intermediate:excel": "ts-node src/main.ts --scenario=intermediate --excel",
    "start:advanced": "ts-node src/main.ts --scenario=advanced",
    "start:advanced:excel": "ts-node src/main.ts --scenario=advanced --excel",
    "start:completion-before-limit": "ts-node src/main.ts --scenario=completion-before-limit",
    "start:completion-before-limit:excel": "ts-node src/main.ts --scenario=completion-before-limit --excel",
    "start:consolidation-audit": "ts-node src/main.ts --scenario=consolidation-audit",
    "start:consolidation-audit:excel": "ts-node src/main.ts --scenario=consolidation-audit --excel",
    "start:rule-pipeline-stress": "ts-node src/main.ts --scenario=rule-pipeline-stress",
    "start:rule-pipeline-stress:excel": "ts-node src/main.ts --scenario=rule-pipeline-stress --excel",
    "start:daily-amount-audit": "ts-node src/main.ts --scenario=daily-amount-audit",
    "start:daily-amount-audit:excel": "ts-node src/main.ts --scenario=daily-amount-audit --excel",
    "start:review-only-reset-stress": "ts-node src/main.ts --scenario=review-only-reset-stress",
    "start:review-only-reset-stress:excel": "ts-node src/main.ts --scenario=review-only-reset-stress --excel",
    "start:review-only": "ts-node src/main.ts --scenario=review-only",
    "start:review-only:excel": "ts-node src/main.ts --scenario=review-only --excel",
    "start:quarter-page": "ts-node src/main.ts --scenario=quarter-page",
    "start:quarter-page:excel": "ts-node src/main.ts --scenario=quarter-page --excel",
    "start:all": "ts-node src/main.ts --all",
    "start:all:excel": "ts-node src/main.ts --all --excel",
    "validate:scenarios": "ts-node src/tests/scenarioValidator.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:legacy": "ts-node src/tests/planErrors.test.ts",
    "prepublishOnly": "npm run test && npm run build"
  },
  "keywords": [
    "quran",
    "memorization",
    "hifz",
    "planning",
    "mushaf",
    "islamic"
  ],
  "devDependencies": {
    "@types/node": "^25.0.3",
    "exceljs": "^4.4.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  }
}
