{
  "name": "maken-core",
  "version": "1.0.0",
  "description": "Quran memorization planning engine — line-precise scheduling with mushaf spatial coordinates.",
  "author": "MakenCore Contributors",
  "license": "ISC",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=16"
  },
  "scripts": {
    "build": "tsc",
    "build:clean": "rmdir /s /q dist 2>nul & tsc",
    "start": "ts-node src/main.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:legacy": "ts-node src/tests/planErrors.test.ts",
    "prepublishOnly": "npm run test && npm run build"
  },
  "keywords": [
    "quran",
    "memorization",
    "hifz",
    "planning",
    "mushaf",
    "islamic"
  ],
  "devDependencies": {
    "@types/node": "^25.0.3",
    "exceljs": "^4.4.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  }
}
